# Server port (default: 3001)
PORT=3001

# MongoDB connection string
# For Docker Compose local dev: mongodb://mongodb:27017/chatting-app
# For MongoDB Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/chatting-app
DATABASE_URL=mongodb://mongodb:27017/chatting-app

# JWT signing secret — use a long random string in production
JWT_KEY=replace_with_a_strong_secret

# Frontend URL for CORS (match whatever port/domain serves the client)
ORIGIN=http://localhost:80

# Groq AI API key (optional — AI chat features disabled if not set)
GROQ_API_KEY=
